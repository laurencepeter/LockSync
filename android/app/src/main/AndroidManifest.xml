<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Network ──────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- ── Notifications (Android 13+) ─────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- ── Background / foreground service (lock screen relay) ─── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <!-- dataSync type required for Android 14+ foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <!-- Prevent the OS from killing the service on low memory -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <!-- Show on lock screen when display is off (keep WS alive) -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Disable the keyguard / lock screen so the app can appear immediately -->
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD"/>
    <!-- Keep WiFi alive in background -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Full-screen intent — wake + show the app over the lock screen.
         On Android 14+ the user must explicitly grant this in System Settings;
         we request it via Settings.ACTION_MANAGE_APP_USE_FULL_SCREEN_INTENTS. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>
    <!-- Draw over other apps (lock screen overlay when app is not in foreground).
         Required for the app to appear on the lock screen without the user
         having had it open last. Runtime request via
         Settings.ACTION_MANAGE_OVERLAY_PERMISSION. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Camera (QR scanner) -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <!-- Wallpaper setting -->
    <uses-permission android:name="android.permission.SET_WALLPAPER"/>

    <!-- Gallery save (scoped storage handles this on Android 10+) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage"/>

    <application
        android:label="LockSync"
        android:name="com.locksync.app.MainApplication"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">

        <!-- Main Flutter activity -->
        <activity
            android:name="com.locksync.app.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:showWhenLocked="true"
            android:turnScreenOn="true">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Custom background service that extends flutter_background_service's
             BackgroundService to register WallpaperPlugin in the background
             engine — this allows the lock screen wallpaper to update even
             when the app is fully closed. -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="dataSync|connectedDevice"
            android:exported="false"
            tools:replace="android:exported"/>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>

    <!-- Required for Android 12+ foreground service scheduling -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
