# LockSync WebSocket Server Configuration
# Copy to .env and fill in your values

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-byte-hex-string

# Internal server port (container-internal, do not change unless you update the Dockerfile/healthcheck)
PORT=8080

# Host port to bind on the Docker host (change this if 8080 is already in use)
HOST_PORT=8080

# Allowed origins (comma-separated). Use * for dev, restrict in production.
ALLOWED_ORIGINS=*

# Pairing code expiry in seconds (default: 300 = 5 minutes)
PAIR_CODE_TTL=300

# JWT access token expiry (default: 7 days)
JWT_EXPIRY=7d

# JWT refresh token expiry (default: 30 days)
JWT_REFRESH_EXPIRY=30d

# Rate limiting: max pairing attempts per IP per minute
PAIR_RATE_LIMIT=10

# Max WebSocket message size in bytes (default: 16KB — enough for keystroke deltas)
MAX_MESSAGE_SIZE=16384
